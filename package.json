{
  "name": "stockbolt",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:phase0": "vitest run tests/integration/phase0-rls.test.ts",
    "test:phase1": "vitest run tests/integration/phase1-verification.test.ts",
    "test:phase2": "vitest run tests/integration/phase2-verification.test.ts",
    "test:phase3": "vitest run tests/integration/phase3-verification.test.ts",
    "test:phase4": "vitest run tests/integration/phase4-verification.test.ts",
    "test:phase5": "vitest run tests/integration/phase5-verification.test.ts",
    "test:phase6": "vitest run tests/integration/phase6-verification.test.ts",
    "test:phase7": "vitest run tests/integration/phase7-verification.test.ts",
    "test:phase8": "vitest run tests/integration/phase8-verification.test.ts",
    "test:phase9": "vitest run tests/integration/phase9-verification.test.ts",
    "test:phase10": "vitest run tests/integration/phase10-verification.test.ts",
    "test:phase11": "vitest run tests/integration/phase11-verification.test.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.0",
    "dayjs": "^1.11.13",
    "i18next": "^23.15.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^15.0.2",
    "react-router-dom": "^6.26.2",
    "zod": "^4.4.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.6.1",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.15.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
