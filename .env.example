# ─── Deployment mode ───────────────────────────────────────────
# cloud | self_hosted   (v1 ships with cloud only; self_hosted is a stub)
VITE_DEPLOYMENT_MODE=cloud

# ─── Supabase (cloud mode) ─────────────────────────────────────
# Get these from: Supabase dashboard → "Connect" button → .env tab
#   VITE_SUPABASE_URL              → Project URL (https://<ref>.supabase.co)
#   VITE_SUPABASE_PUBLISHABLE_KEY  → starts with sb_publishable_...
# NEVER put the Secret key here — that's server-side only and would bypass RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Self-hosted mode (only set when VITE_DEPLOYMENT_MODE=self_hosted) ───
VITE_API_URL=

# ─── Localization defaults ─────────────────────────────────────
# en | ar
VITE_DEFAULT_LANGUAGE=en
# AE | SA | KW | BH | OM | QA | IN
VITE_DEFAULT_COUNTRY=AE

# ─── Feature flags ─────────────────────────────────────────────
VITE_ENABLE_DEBUG_PANEL=false
